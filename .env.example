# Daisy Platform — local environment.
# Copy this file to .env and fill values from docs/credentials.md.
# .env is gitignored; never commit real keys.

# Supabase (single shared project across portal / booking / medical)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Maps — browser key only. Restricted to the Maps JavaScript API.
# The server-side Geocoding key (GOOGLE_MAPS_API_KEY) lives in Supabase
# Edge Function secrets, NOT here. Same goes for SERVICE_ROLE_KEY,
# Stripe / GoCardless / Postmark — none of those belong in the client.
VITE_GOOGLE_MAPS_API_KEY=
